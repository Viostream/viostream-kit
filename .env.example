# Viostream SDK — Environment Variables
#
# Copy this file to .env in your app root and uncomment the variables you need.

# Override the Viostream API hostname (defaults to play.viostream.com).
# Use this to point the SDK at a development or staging environment.
#
# For SvelteKit apps, use PUBLIC_VIOSTREAM_HOST:
# PUBLIC_VIOSTREAM_HOST=dev.viostream.com
#
# For plain Vite apps (React, Vue, etc.), use VITE_VIOSTREAM_HOST:
# VITE_VIOSTREAM_HOST=dev.viostream.com
