{
  "name": "@viostream/viostream-player-angular",
  "version": "0.1.13",
  "description": "Angular 17+ SDK for the Viostream video player — embed, control, and listen to player events",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "prebuild": "node ../../scripts/sync-version.mjs",
    "build": "ng-packagr -p ng-package.json",
    "check": "tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@viostream/viostream-player-core": "^0.2.12",
    "debug": "^4.4.3",
    "tslib": "^2.8.0"
  },
  "peerDependencies": {
    "@angular/common": "^17.0.0 || ^18.0.0 || ^19.0.0 || ^20.0.0 || ^21.0.0 || ^22.0.0",
    "@angular/core": "^17.0.0 || ^18.0.0 || ^19.0.0 || ^20.0.0 || ^21.0.0 || ^22.0.0"
  },
  "devDependencies": {
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/platform-browser": "^22.0.5",
    "@angular/platform-browser-dynamic": "^22.0.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/debug": "^4.1.13",
    "jsdom": "^28.1.0",
    "ng-packagr": "^22.0.0",
    "rxjs": "^7.8.0",
    "typescript": "~6.0.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.18",
    "zone.js": "^0.15.0"
  },
  "keywords": [
    "angular",
    "viostream",
    "video",
    "player",
    "embed",
    "sdk"
  ]
}