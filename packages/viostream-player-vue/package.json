{
  "name": "@viostream/viostream-player-vue",
  "version": "0.2.5",
  "description": "Vue 3 SDK for the Viostream video player — embed, control, and listen to player events",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "prebuild": "node ../../scripts/sync-version.mjs",
    "build": "vue-tsc -b && vite build",
    "check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "dependencies": {
    "@viostream/viostream-player-core": "^0.2.5",
    "debug": "^4.4.3"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/debug": "^4.1.13",
    "@vitejs/plugin-vue": "^5.2.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "viostream",
    "video",
    "player",
    "embed",
    "sdk"
  ]
}
