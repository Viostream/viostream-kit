{
  "name": "@viostream/viostream-player-core",
  "version": "0.2.5",
  "description": "Framework-agnostic core for the Viostream player SDK — script loader, player wrapper, and TypeScript types",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "prebuild": "node ../../scripts/sync-version.mjs",
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "!dist/tests"
  ],
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "viostream",
    "video",
    "player",
    "embed",
    "sdk"
  ],
  "dependencies": {
    "debug": "^4.4.3"
  }
}
